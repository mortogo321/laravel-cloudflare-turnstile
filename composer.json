{
    "name": "mortogo321/laravel-cloudflare-turnstile",
    "description": "Laravel wrapper package for Cloudflare Turnstile with invisible mode, button disabling, and auto-refresh",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "laravel",
        "cloudflare",
        "turnstile",
        "captcha",
        "security"
    ],
    "homepage": "https://github.com/mortogo321/laravel-cloudflare-turnstile",
    "authors": [
        {
            "name": "Mor",
            "email": "mortogo321@gmail.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "illuminate/support": "^10.0|^11.0",
        "illuminate/validation": "^10.0|^11.0",
        "guzzlehttp/guzzle": "^7.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0",
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "Mortogo321\\LaravelCloudflareTurnstile\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Mortogo321\\LaravelCloudflareTurnstile\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Mortogo321\\LaravelCloudflareTurnstile\\TurnstileServiceProvider"
            ],
            "aliases": {
                "Turnstile": "Mortogo321\\LaravelCloudflareTurnstile\\Facades\\Turnstile"
            }
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
